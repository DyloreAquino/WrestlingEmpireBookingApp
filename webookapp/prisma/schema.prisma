// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////
// ENUMS
//////////////////////

enum Role {
  WRESTLER
  BOOKER
  REFEREE
  MANAGER
}

enum Gender {
  MALE
  FEMALE
  NA
}

enum Alignment {
  FACE
  HEEL
  TWEENER
}

enum Division {
  TOP_CARD
  MID_CARD
  UNDER_CARD
  TAG
}

enum TitleGender {
  MALE
  FEMALE
  ALL
}

enum ShowType {
  TV
  PPV
}

enum Month {
  JAN
  FEB
  MAR
  APR
  MAY
  JUN
  JUL
  AUG
  SEP
  OCT
  NOV
  DEC
}

enum MatchType {
  SINGLES
  TAG_TEAM
  TEAM
  TRIPLE_THREAT
  FATAL_FOUR_WAY
  HANDICAP
  GAUNTLET
  BATTLE_ROYALE
  ROYAL_RUMBLE
}

enum Stipulation {
  HARDCORE
  OPEN_CHALLENGE
  CONFRONTATION
  BEST_OF_THREE
  IRONMAN
  LAST_LAUGH
  SUBMISSION
  LAST_MAN_STANDING
  STREET_FIGHT
  FIRST_BLOOD
  SUMO_CONTEST
  SHOOT_FIGHT
  TAG_ELIMINATION
  WAR
  ELIMINATION
  ESCAPE_TO_VICTORY
  FURNITURE_SMASH
  LADDER
  HELL_IN_A_CELL
  TRAINING
}

enum FinishType {
  PINFALL
  SUBMISSION
  COUNTOUT
  DQ
  INTERFERENCE
  UNIQUE
  UNFINISHED
}

enum CardPlacement {
  UNDERCARD
  MIDCARD
  SEMI_MAIN
  MAIN
}

//////////////////////
// CORE MODELS
//////////////////////

model User {
  id               Int         @id @default(autoincrement())
  email            String      @unique
  passwordHash     String
  activeUniverseId Int?
  universes        Universe[]
  createdAt        DateTime    @default(now())
}

model Universe {
  id          Int           @id @default(autoincrement())
  name        String
  userId      Int
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  characters    Character[]
  championships Championship[]
  shows         Show[]
  factions      Faction[]
  tagTeams      TagTeam[]
  rivalries     Rivalry[]
  friendships   Friendship[]
}

model Character {
  id           Int          @id @default(autoincrement())
  universeId   Int
  universe     Universe     @relation(fields: [universeId], references: [id], onDelete: Cascade)
  name         String
  role         Role
  gender       Gender
  alignment    Alignment
  division     Division
  finisherName String?
  injured      Boolean      @default(false)

  factionId    Int?
  faction      Faction?     @relation(fields: [factionId], references: [id])

  tagTeamId    Int?
  tagTeam      TagTeam?     @relation(fields: [tagTeamId], references: [id])

  rivalryId    Int?
  rivalry      Rivalry?     @relation(fields: [rivalryId], references: [id])

  friendshipId Int?
  friendship   Friendship?  @relation(fields: [friendshipId], references: [id])

  matchEntries  MatchParticipant[]
  interferences MatchInterference[]
  titleReigns   TitleReign[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Championship {
  id           Int         @id @default(autoincrement())
  universeId   Int
  universe     Universe    @relation(fields: [universeId], references: [id], onDelete: Cascade)
  name         String
  division     Division
  gender       TitleGender

  reigns    TitleReign[]
  matches   Match[]
}

model Show {
  id           Int      @id @default(autoincrement())
  universeId   Int
  universe     Universe @relation(fields: [universeId], references: [id], onDelete: Cascade)
  title        String?
  type         ShowType
  month        Month
  year         Int      @default(1)
  location     String   @default("Parts Unknown")
  week         Int
  updatedAt    DateTime @updatedAt @default(now())
  createdAt    DateTime @default(now())

  matches      Match[]
  titleReigns  TitleReign[]
}

model TitleReign {
  id             Int          @id @default(autoincrement())
  championshipId Int
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  characterId    Int
  character      Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  showId         Int?
  show           Show?        @relation(fields: [showId], references: [id])
  startMonth     Month?
  startWeek      Int?
  startYear      Int?
  endMonth       Month?
  endWeek        Int?
  endYear        Int?
  startDate      DateTime
  endDate        DateTime?
  isCurrent      Boolean      @default(true)
}

model Match {
  id             Int              @id @default(autoincrement())
  title          String?
  matchType      MatchType
  stipulation    Stipulation?
  finish         FinishType
  placement      CardPlacement    @default(UNDERCARD)

  championshipId Int?
  championship   Championship?    @relation(fields: [championshipId], references: [id])

  showId         Int
  show           Show             @relation(fields: [showId], references: [id])

  participants   MatchParticipant[]
  interferences  MatchInterference[]

  createdAt      DateTime @default(now())
}

model MatchParticipant {
  id          Int       @id @default(autoincrement())
  matchId     Int
  characterId Int
  isWinner    Boolean   @default(false)

  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model MatchInterference {
  id          Int       @id @default(autoincrement())
  matchId     Int
  characterId Int

  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

//////////////////////
// SINGLE-MEMBER STRUCTURES
//////////////////////

model Faction {
  id         Int         @id @default(autoincrement())
  universeId Int
  universe   Universe    @relation(fields: [universeId], references: [id], onDelete: Cascade)
  name       String
  members    Character[]
}

model TagTeam {
  id         Int         @id @default(autoincrement())
  universeId Int
  universe   Universe    @relation(fields: [universeId], references: [id], onDelete: Cascade)
  name       String
  members    Character[]
}

model Rivalry {
  id         Int         @id @default(autoincrement())
  universeId Int
  universe   Universe    @relation(fields: [universeId], references: [id], onDelete: Cascade)
  name       String?
  intensity  Int         @default(1)
  members    Character[]
}

model Friendship {
  id         Int         @id @default(autoincrement())
  universeId Int
  universe   Universe    @relation(fields: [universeId], references: [id], onDelete: Cascade)
  strength   Int         @default(1)
  members    Character[]
}
